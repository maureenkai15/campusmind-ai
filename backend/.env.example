# ──────────────────────────────────────────────
#  CampusMind AI – Backend Environment Variables
# ──────────────────────────────────────────────

# App
APP_NAME="CampusMind AI"
APP_ENV=development          # development | production
DEBUG=true
SECRET_KEY=change-me-to-a-random-256-bit-secret

# Server
HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS='["http://localhost:3000","http://127.0.0.1:3000"]'

# Database
DATABASE_URL=sqlite+aiosqlite:///./campusmind.db
# For PostgreSQL: postgresql+asyncpg://user:password@localhost:5432/campusmind

# JWT Auth
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# AI / Ollama (local, no API key needed)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2          # or mistral, phi3, gemma2 etc.
EMBEDDING_MODEL=nomic-embed-text

# NTU Campus Data
NTU_CAMPUS_CENTER_LAT=1.3483
NTU_CAMPUS_CENTER_LNG=103.6831
